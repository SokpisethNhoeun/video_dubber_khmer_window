# Hugging Face API Token (needed for speaker diarization / pyannote)
HF_TOKEN=your_hugging_face_token_here

# ElevenLabs API Key (needed for production-quality speech-to-speech cloning)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Hugging Face Endpoint Configuration
HF_ENDPOINT=https://huggingface.co
HF_HUB_DISABLE_IPV6=1
VOICE_CLONE_BACKEND=local_openvoice
OPENVOICE_PYTHON=/absolute/path/to/OpenVoice/.venv/bin/python
OPENVOICE_CHECKPOINT_DIR=/absolute/path/to/OpenVoice/checkpoints_v2
OPENVOICE_DEVICE=auto

# Qwen3-TTS 1.7B voice clone (optional — best quality + emotion via source clips)
# pip install qwen-tts  (in a separate Python 3.10+ venv with CUDA)
QWEN3_TTS_PYTHON=/absolute/path/to/qwen3-tts/.venv/bin/python
QWEN3_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
# For 6GB GPUs (e.g. RTX 3060) with the 1.7B model, these are applied automatically.
# You can set them explicitly:
# QWEN3_TTS_LOW_VRAM=1
# QWEN3_TTS_DTYPE=float16
# Default is to stop if Qwen3 clone cannot load/generate, so the app does not
# create output with the wrong default TTS voice. Set to 1 only if fallback is OK.
# QWEN3_TTS_ALLOW_FALLBACK=0

# Gemini expressive Khmer TTS (optional)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_FALLBACK=your_gemini_api_key_fallback_here
# GEMINI_API_KEYS=key1,key2,key3
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_MAX_REQUESTS=15 q q
GEMINI_TTS_MAX_SEGMENTS_PER_CHUNK=8
GEMINI_TTS_MAX_CHUNK_DURATION_SEC=30
GEMINI_TTS_RATE_LIMIT_RETRIES=20

# AI transcript review / translation powered by Google AI Studio.
# Desktop customers normally enter GEMINI_API_KEY during onboarding, so do not
# ship TRANSCRIPT_REVIEW_API_KEY in the Windows installer. The optional alias
# below is also treated as a Google Gemini key when it is set.
# TRANSCRIPT_REVIEW_API_KEY=your_google_ai_studio_key_here
TRANSCRIPT_REVIEW_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
TRANSCRIPT_REVIEW_MODEL=gemini-3.1-flash-lite

# Hosted license server only. Never bundle these secrets with the desktop app.
LICENSE_DB_PATH=/var/lib/khmer-video-dubber/licenses.db
LICENSE_PUBLIC_URL=https://license.example.com
LICENSE_ADMIN_TOKEN=
ADMIN_BOOTSTRAP_EMAIL=owner@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-long-random-password
ADMIN_SESSION_HOURS=12
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Khmer Video Dubber <licenses@example.com>
SMTP_TLS=true
